<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Веб-сканер штрихкодов</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f6f9;
            color: #333;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .container {
            max-width: 600px;
            width: 100%;
            background: #fff;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            text-align: center;
        }
        #interactive.viewport {
            position: relative;
            width: 100%;
            height: 300px;
            background: #000;
            border-radius: 6px;
            overflow: hidden;
            margin: 20px 0;
        }
        #interactive.viewport video, canvas {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        #output {
            margin-top: 20px;
            padding: 15px;
            background: #2c3e50;
            color: #ecf0f1;
            border-radius: 4px;
            font-family: monospace;
            white-space: pre-wrap;
            text-align: left;
            max-height: 150px;
            overflow-y: auto;
        }
        button {
            background-color: #3498db;
            color: white;
            border: none;
            padding: 12px 24px;
            font-size: 16px;
            border-radius: 4px;
            cursor: pointer;
            transition: background 0.3s;
        }
        button:hover {
            background-color: #2980b9;
        }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/quagga/0.12.1/quagga.min.js"></script>
</head>
<body>

<div class="container">
    <h1>Сканер штрихкодов</h1>
    <button onclick="startScanner()">Включить сканер</button>
    
    <div id="interactive" class="viewport"></div>

    <h3>Результат сканирования:</h3>
    <div id="output">Нажмите кнопку для запуска сканера...</div>
</div>

<script>
    function startScanner() {
        const outputDiv = document.getElementById('output');
        outputDiv.textContent = "Инициализация камеры...";

        Quagga.init({
            inputStream: {
                name: "Live",
                type: "LiveStream",
                target: document.querySelector('#interactive'),
                constraints: {
                    width: 640,
                    height: 480,
                    facingMode: "environment" // Задняя камера
                },
            },
            decoder: {
                readers: ["ean_reader", "ean_8_reader", "code_128_reader"] // Форматы штрихкодов
            }
        }, function (err) {
            if (err) {
                console.error(err);
                outputDiv.textContent = "Ошибка запуска: " + err.message;
                return;
            }
            console.log("Initialization finished. Ready to start");
            Quagga.start();
            outputDiv.textContent = "Сканер запущен. Наведите камеру на штрихкод.";
        });

        // Логика обработки распознанного штрихкода из вашего коммита
        Quagga.onDetected(function (data) {
            const code = data.codeResult.code;
            document.getElementById('output').textContent = "Распознан код: " + code;
            
            // Проверка условий из оригинального скрипта
            if (code.startsWith("460")) {
                alert("Это Молоко Домик в деревне!");
            } else if (code.startsWith("467")) {
                alert("Это Сыр Ламбер!");
            } else if (code === "4600605021571") {
                alert("Это Шоколад Аленка!");
            } else if (code === "4640001150111") {
                alert("Это Сок Добрый Яблоко!");
            } else {
                console.log("Неизвестный штрихкод: " + code);
            }
        });
    }
</script>

</body>
</html>
